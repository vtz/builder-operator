                    <mxGeometry x="140" y="700" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_d1_t" value="&lt;b&gt;Page 3: Factory Topology&lt;/b&gt;&lt;br&gt;Zone 1 (Forge) → Zone 2 (Virtual)&lt;br&gt;→ Zone 3 (Physical) → Feedback Loop&lt;br&gt;Tech stack, tools, commands" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="145" y="703" width="290" height="58" as="geometry"/>
