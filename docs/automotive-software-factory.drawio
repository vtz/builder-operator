    <diagram id="elevator" name="6 - The Architect Elevator (Navigation)">
        <mxGraphModel dx="765" dy="787" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" background="#FFFFFF" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p6_title" value="The Architect Elevator — Multi-Audience Communication" style="text;html=1;fontSize=22;fontStyle=1;fontFamily=Red Hat Text;fontColor=#EE0000;align=left;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="700" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p6_subtitle" value="After Gregor Hohpe: The architect's job is to ride the elevator between the penthouse and the engine room, connecting the two with clarity." style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#707070;align=left;fontStyle=2;" parent="1" vertex="1">
                    <mxGeometry x="40" y="58" width="800" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_shaft" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#151515;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="60" height="750" as="geometry"/>
                </mxCell>
                <mxCell id="p6_shaft_label" value="&lt;b&gt;A&lt;br&gt;R&lt;br&gt;C&lt;br&gt;H&lt;br&gt;I&lt;br&gt;T&lt;br&gt;E&lt;br&gt;C&lt;br&gt;T&lt;br&gt;&lt;br&gt;E&lt;br&gt;L&lt;br&gt;E&lt;br&gt;V&lt;br&gt;A&lt;br&gt;T&lt;br&gt;O&lt;br&gt;R&lt;/b&gt;" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#FFFFFF;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="45" y="120" width="50" height="700" as="geometry"/>
                </mxCell>
                <mxCell id="p6_car" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EE0000;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="50" y="280" width="40" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0066CC;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="120" y="100" width="1440" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_label" value="&lt;b&gt;PENTHOUSE&lt;/b&gt;" style="text;html=1;fontSize=18;fontStyle=1;fontFamily=Red Hat Text;fontColor=#FFFFFF;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="108" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_who" value="C-Suite / Board" style="text;html=1;fontSize=12;fontFamily=Red Hat Text;fontColor=#E0F0FF;align=left;" parent="1" vertex="1">
                    <mxGeometry x="320" y="112" width="150" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_time" value="5-10 min" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#E0F0FF;align=left;" parent="1" vertex="1">
                    <mxGeometry x="480" y="114" width="80" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_q" value="&lt;b&gt;They Ask:&lt;/b&gt; &quot;Why should we invest in this?  What's the ROI?  How does this beat Tesla?&quot;" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#FFFFFF;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="140" width="700" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_a" value="&lt;b&gt;You Show:&lt;/b&gt;  Page 1 (Executive Overview) — The Bet, Market Size ($462B), 6 Capabilities Loop, Value Proposition" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#FFFFFF;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="165" width="800" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_pitch" value="&lt;i&gt;&quot;We're not selling an OS — we're selling the factory that makes your software strategy viable.&quot;&lt;/i&gt;" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#E0F0FF;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="195" width="700" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_ref" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;opacity=20;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="110" width="440" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f4_ref_t" value="&lt;b&gt;→ Page 1: Executive Overview&lt;/b&gt;&lt;br&gt;&lt;br&gt;• The 6-Capability Loop&lt;br&gt;• Problem → Solution → Value&lt;br&gt;• The Bet (bottom strip)&lt;br&gt;• Why Now + Why Red Hat" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1110" y="113" width="420" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F0FF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="120" y="260" width="1440" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_label" value="&lt;b&gt;MANAGEMENT&lt;/b&gt;" style="text;html=1;fontSize=18;fontStyle=1;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="268" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_who" value="VPs / Directors" style="text;html=1;fontSize=12;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="340" y="272" width="150" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_time" value="10-15 min" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#707070;align=left;" parent="1" vertex="1">
                    <mxGeometry x="500" y="274" width="80" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_q" value="&lt;b&gt;They Ask:&lt;/b&gt; &quot;What's the adoption path?  Where do we start?  How does this fit our maturity level?&quot;" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="300" width="700" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_a" value="&lt;b&gt;You Show:&lt;/b&gt;  Page 5 (Adoption Journey) — Three Phases, Entry Points by Pain, OEM Profiles, Engagement Model" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="325" width="800" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_pitch" value="&lt;i&gt;&quot;Start with your biggest pain point. Build (3-6 mo), then Certify + Validate (6-12 mo), then close the loop (12-24 mo).&quot;&lt;/i&gt;" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#707070;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="355" width="700" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_ref" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="270" width="440" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f3_ref_t" value="&lt;b&gt;→ Page 5: OEM Adoption Journey&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Phase 1-2-3 progression&lt;br&gt;• Entry points by customer pain&lt;br&gt;• OEM profile matching&lt;br&gt;• Engagement model" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1110" y="273" width="420" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="120" y="420" width="1440" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_label" value="&lt;b&gt;ARCHITECTURE&lt;/b&gt;" style="text;html=1;fontSize=18;fontStyle=1;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="428" width="220" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_who" value="Solution Architects" style="text;html=1;fontSize=12;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="365" y="432" width="150" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_time" value="20 min" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#707070;align=left;" parent="1" vertex="1">
                    <mxGeometry x="530" y="434" width="80" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_q" value="&lt;b&gt;They Ask:&lt;/b&gt; &quot;What are the trade-offs?  What options does this architecture create?  How do the capabilities connect?&quot;" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="460" width="700" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_a" value="&lt;b&gt;You Show:&lt;/b&gt;  Page 2 (Six Capabilities Pipeline) — Forward + feedback paths, architectural options, Hohpe's &quot;Selling Options&quot;" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="485" width="800" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_pitch" value="&lt;i&gt;&quot;Target flexibility buys the option to change silicon vendors at known cost. Environmental parity buys the option to shift validation left and decouple test authoring from execution target. The factory's value is in the decisions it allows you to defer.&quot;&lt;/i&gt;" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#707070;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="515" width="900" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_ref" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="430" width="440" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f2_ref_t" value="&lt;b&gt;→ Page 2: Six Capabilities Pipeline&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Forward path: Code → Car&lt;br&gt;• Feedback path: Car → Code&lt;br&gt;• Architectural options per capability&lt;br&gt;• Maturity status (GA / Dev / Concept / Integration)&lt;br&gt;• Hohpe's &quot;Selling Options&quot; framing" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1110" y="433" width="420" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="120" y="600" width="1440" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_label" value="&lt;b&gt;ENGINE ROOM&lt;/b&gt;" style="text;html=1;fontSize=18;fontStyle=1;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="608" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_who" value="Engineers / DevOps / Embedded" style="text;html=1;fontSize=12;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="350" y="612" width="250" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_time" value="30+ min" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#707070;align=left;" parent="1" vertex="1">
                    <mxGeometry x="610" y="614" width="80" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_q" value="&lt;b&gt;They Ask:&lt;/b&gt; &quot;How does the pipeline work?  What tools do we use?  How do I test MCU firmware in CI/CD? Show me the commands.&quot;" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="640" width="800" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_a" value="&lt;b&gt;You Show:&lt;/b&gt;  Page 3 (Factory Topology) + Page 4 (Jumpstarter V&amp;V Matrix)" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="140" y="665" width="700" height="22" as="geometry"/>
                </mxCell>
