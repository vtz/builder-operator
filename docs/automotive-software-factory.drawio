                <mxCell id="p5_e6_t" value="&lt;b&gt;&quot;MCU bench testing is manual and slow&quot;&lt;/b&gt;&lt;br&gt;Lead: &lt;b&gt;Jumpstarter&lt;/b&gt; (Physical probe-rs)&lt;br&gt;Ask: &quot;How do you flash and test MCU firmware today?&quot;" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="683" width="340" height="64" as="geometry"/>
