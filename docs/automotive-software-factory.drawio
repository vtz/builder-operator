                    <mxGeometry x="460" y="700" width="300" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="p6_f1_d2_t" value="&lt;b&gt;Page 4: Jumpstarter V&amp;V Matrix&lt;/b&gt;&lt;br&gt;2x2: Virtual/Physical × SoC/MCU&lt;br&gt;Drivers, flash methods, scale targets&lt;br&gt;CI/CD integration, jmp CLI" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="465" y="703" width="290" height="58" as="geometry"/>
