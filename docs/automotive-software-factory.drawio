                <mxCell id="p5_entry_label" value="&lt;b&gt;Entry Points by Customer Pain&lt;/b&gt;" style="text;html=1;fontSize=16;fontStyle=1;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
