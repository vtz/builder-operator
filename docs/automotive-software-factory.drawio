                </mxCell>
                <mxCell id="p5_e1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F0FF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="65" y="520" width="350" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e1_t" value="&lt;b&gt;&quot;Certification is killing our timeline&quot;&lt;/b&gt;&lt;br&gt;Lead: &lt;b&gt;CaaS&lt;/b&gt;&lt;br&gt;Ask: &quot;How much of your certification is manual documentation?&quot;" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="523" width="340" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F0FF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="65" y="600" width="350" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e2_t" value="&lt;b&gt;&quot;We can't hire QNX developers&quot;&lt;/b&gt;&lt;br&gt;Lead: &lt;b&gt;Image Builder&lt;/b&gt; (open-source toolchains)&lt;br&gt;Ask: &quot;How many open reqs for embedded Linux vs. QNX?&quot;" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="603" width="340" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F0FF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="65" y="680" width="350" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e3_t" value="&lt;b&gt;&quot;Our validation is a bottleneck&quot;&lt;/b&gt;&lt;br&gt;Lead: &lt;b&gt;Jumpstarter&lt;/b&gt; (Virtual V&amp;V)&lt;br&gt;Ask: &quot;How many HIL rigs, and what's utilization?&quot;" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="683" width="340" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="445" y="520" width="350" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e4_t" value="&lt;b&gt;&quot;We don't know what's happening in field&quot;&lt;/b&gt;&lt;br&gt;Lead: &lt;b&gt;Observability / Fleet Monitoring&lt;/b&gt;&lt;br&gt;Ask: &quot;How long does RCA take when a field issue is reported?&quot;" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="523" width="340" height="64" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e5" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0E0E0;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="445" y="600" width="350" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p5_e5_t" value="&lt;b&gt;&quot;SoC and MCU teams live in different worlds&quot;&lt;/b&gt;&lt;br&gt;Lead: &lt;b&gt;Jumpstarter&lt;/b&gt; (Unified V&amp;V)&lt;br&gt;Ask: &quot;Do SoC and MCU teams share a test framework?&quot;" style="text;html=1;fontSize=9;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="603" width="340" height="64" as="geometry"/>
                </mxCell>
