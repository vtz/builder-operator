                <mxCell id="p1_v3_t" value="&lt;b&gt;60-80%&lt;/b&gt; validation cost reduction&lt;br&gt;Virtual V&amp;V replaces $500K+ physical test rigs for 80% of tests" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=5;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="257" width="320" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p1_v4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F0FF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="310" width="330" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="p1_v4_t" value="&lt;b&gt;10-65x&lt;/b&gt; larger talent pool&lt;br&gt;Linux/cloud engineers vs. QNX/AUTOSAR specialists" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=5;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="312" width="320" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p1_v5" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E0F0FF;strokeColor=#0066CC;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="365" width="330" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="p1_v5_t" value="&lt;b&gt;OS-Agnostic&lt;/b&gt;  Not forcing an OS choice&lt;br&gt;Factory works with Linux, QNX, Android, AUTOSAR, bare-metal" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=5;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="367" width="320" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p1_v6" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D1F1BB;strokeColor=#63993D;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="420" width="330" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="p1_v6_t" value="&lt;b&gt;Open Source, No Lock-In&lt;/b&gt;&lt;br&gt;Subscription economics, community innovation, full transparency" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;spacingLeft=5;" parent="1" vertex="1">
                    <mxGeometry x="1220" y="422" width="320" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p1_bet" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#151515;strokeColor=none;" parent="1" vertex="1">
                    <mxGeometry x="40" y="590" width="1530" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="p1_bet_t" value="&lt;b&gt;THE BET:&lt;/b&gt;  OEMs need a factory, not just an OS or a tool. The winner sells the complete, OS-agnostic pipeline. Each capability reinforces the others — compound value that no point-solution competitor can match." style="text;html=1;fontSize=12;fontFamily=Red Hat Text;fontColor=#FFFFFF;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="60" y="595" width="1490" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="p1_pitch" value="&lt;i&gt;&quot;We're not selling an OS — we're selling the factory that makes your software strategy viable.&quot;&lt;/i&gt;" style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#EE0000;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="660" width="1530" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="p1_market" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="40" y="700" width="740" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="p1_market_label" value="&lt;b&gt;Why Now: Five Forcing Functions&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="65" y="708" width="300" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p1_m1" value="&lt;b&gt;1.&lt;/b&gt; Software complexity explosion — 150M+ lines of code per vehicle" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="65" y="733" width="400" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_m2" value="&lt;b&gt;2.&lt;/b&gt; Tesla's cadence standard — weekly OTA resets customer expectations" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="65" y="755" width="400" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_m3" value="&lt;b&gt;3.&lt;/b&gt; Regulation tightens — UN R155/R156 mandates effective July 2024" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="65" y="777" width="400" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_m4" value="&lt;b&gt;4.&lt;/b&gt; Talent economics — the talent pool determines the platform" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="65" y="799" width="400" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_m5" value="&lt;b&gt;5.&lt;/b&gt; Certification as bottleneck — incompatible with continuous delivery" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="65" y="821" width="400" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_why" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#707070;" parent="1" vertex="1">
                    <mxGeometry x="810" y="700" width="760" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="p1_why_label" value="&lt;b&gt;Why Red Hat&lt;/b&gt;" style="text;html=1;fontSize=12;fontStyle=1;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="835" y="708" width="200" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p1_w1" value="&lt;b&gt;Complete Pipeline&lt;/b&gt;  Unlike QNX (OS), Wind River (OS+tools), NVIDIA (AD stack) — we deliver the entire factory" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="835" y="733" width="700" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_w2" value="&lt;b&gt;OS-Agnostic&lt;/b&gt;  Builds and validates for ANY in-vehicle stack. We don't force an OS choice; we industrialize whatever you choose" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="835" y="755" width="700" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_w3" value="&lt;b&gt;Open Source Economics&lt;/b&gt;  Largest developer talent pool, no lock-in, transparent security" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="835" y="777" width="700" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_w4" value="&lt;b&gt;Enterprise Scale&lt;/b&gt;  OpenShift runs production workloads for financial services, telco, and government" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="835" y="799" width="700" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="p1_w5" value="&lt;b&gt;Subscription Flywheel&lt;/b&gt;  Continuous value: new features, security patches, compliance updates — no renegotiation" style="text;html=1;fontSize=10;fontFamily=Red Hat Text;fontColor=#151515;align=left;" parent="1" vertex="1">
                    <mxGeometry x="835" y="821" width="700" height="18" as="geometry"/>
                </mxCell>
            </root>
