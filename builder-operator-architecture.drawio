                <mxCell id="ob_title" value="Option B: Tekton Pipelines + Operator as Orchestrator" style="text;html=1;fontSize=20;fontStyle=1;fontFamily=Red Hat Text;fontColor=#EE0000;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="700" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="ob_subtitle" value="The operator manages a dedicated namespace with pre-built Tekton Pipelines. Developers don't interact with Tekton directly." style="text;html=1;fontSize=11;fontFamily=Red Hat Text;fontColor=#707070;align=left;" parent="1" vertex="1">
                    <mxGeometry x="40" y="55" width="800" height="20" as="geometry"/>
