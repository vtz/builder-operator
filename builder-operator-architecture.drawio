    <diagram id="option-b-tekton" name="5 - Option B: Tekton as Execution Engine">
        <mxGraphModel dx="939" dy="787" grid="0" gridSize="5" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" background="#ffffff" math="0" shadow="0">
